# Copy to .env and fill in real values before `docker compose up`
NODE_ENV=production

# Secrets — must be ≥32 chars
JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string_at_least_32_chars

# Frontend → backend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Optional: TURN server (recommended for production calls)
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=turn-user
# VITE_TURN_CREDENTIAL=turn-secret

# Cloudinary (file uploads)
# CLOUDINARY_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
